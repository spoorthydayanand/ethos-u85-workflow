config MLEK_EXAMPLES_LIB
    bool "Add Arm MLEK examples library"
    default n
    help
        Include ML Embedded Evaluation Kit examples library.

if MLEK_EXAMPLES_LIB
    choice MLEK_EXAMPLES_FRAMEWORK
        bool "Machine learning framework to use with MLEK examples"
        default MLEK_EXAMPLES_FWK_TFLM

        config MLEK_EXAMPLES_FWK_TFLM
            bool "MLEK with TensorFlow Lite Micro framework"
            depends on TENSORFLOW_LITE_MICRO && CMSIS_DSP
            help
                Enable Arm MLEK examples to use TensorFlow Lite Micro framework.

        config MLEK_EXAMPLES_FWK_EXECUTORCH
            bool "MLEK with ExecuTorch framework"
            depends on EXECUTORCH && CMSIS_DSP
            help
                Enable Arm MLEK examples to use ExecuTorch framework.
    endchoice # MLEK_EXAMPLES_FRAMEWORK

    config MLEK_EXAMPLES_LOG_ENABLE
        bool "Arm MLEK logging"
        default n
        help
            Enable logging for Arm MLEK libraries and examples.

    if MLEK_EXAMPLES_LOG_ENABLE
        choice MLEK_EXAMPLES_LOG_LEVEL
            bool "MLEK log level choice"
            default MLEK_EXAMPLES_LOG_LEVEL_INFO

            config MLEK_EXAMPLES_LOG_LEVEL_TRACE
                bool "Trace"

            config MLEK_EXAMPLES_LOG_LEVEL_DEBUG
                bool "Debug"

            config MLEK_EXAMPLES_LOG_LEVEL_INFO
                bool "Info"

            config MLEK_EXAMPLES_LOG_LEVEL_WARN
                bool "Warn"

            config MLEK_EXAMPLES_LOG_LEVEL_ERROR
                bool "Error"
        endchoice # MLEK_EXAMPLES_LOG_LEVEL
    endif # MLEK_EXAMPLES_LOG_ENABLE
endif # MLEK_EXAMPLES_LIB
